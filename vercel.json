{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https:; frame-src 'self' https://datawrapper.dwcdn.net https://*.datawrapper.de https://*.datawrapper.dwcdn.net;"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/ping-supabase",
      "schedule": "0 12 * * *"
    }
  ]
}
